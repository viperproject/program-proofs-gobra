package chapter01

// Exercise 1.9.
// Gobra does not support the apostrophe ('). From now on,
// We will suffix our functions with "Prime" instead.

// The body of this function does not satisfy the contract of Triple.
// To see the error that is produced, remove the "trusted" annotation
// below.
trusted
ensures  Average_v1(r, 3 * x) == 3 * x
decreases
pure func TriplePrime(x int) (r int) {
	return 3 * x + 1
}
